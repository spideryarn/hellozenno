{% extends "base.jinja" %}

{% block breadcrumbs %}
    » Languages
{% endblock breadcrumbs %}

{% block title %}
Hello Zenno - learn foreign words, with a magical AI dictionary
{% endblock %}

{% block meta_description %}
Learn vocabulary and phrases in any language.
{% endblock %}

{% block content %}
<div class="container py-4">
    <h1 class="mb-4">Available Languages ({{ languages|length }})</h1>
    
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        {% for language in languages %}
            <div class="col">
                <a href="{{ url_for('sourcedir_views.sourcedirs_for_language_vw', target_language_code=language.code) }}" class="text-decoration-none">
                    <div class="hz-language-item">
                        <h3>{{ language.name }}</h3>
                        <span class="hz-metadata">({{ language.code }})</span>
                    </div>
                </a>
            </div>
        {% else %}
            <div class="col">
                <div class="hz-language-item">
                    <p class="text-muted">No languages available</p>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %} 