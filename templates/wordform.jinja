{% extends "base.jinja" %}

{% block title %}
{{ wordform_metadata.wordform }} in {{ target_language_name }} (wordform) - Hello Zenno
{% endblock %}

{% block breadcrumbs %}
    » <a href="{{ url_for('core_views.languages_list_vw') }}">Languages</a>
    » <a href="{{ url_for('sourcedir_views.sourcedirs_for_language_vw', target_language_code=target_language_code) }}">{{ target_language_name }}</a>
    » <a href="{{ url_for('wordform_views.wordforms_list_vw', target_language_code=target_language_code) }}">Wordforms</a>
    » {{ wordform_metadata.wordform }}
{% endblock breadcrumbs %}

{% block content %}
<div class="container py-4">
    <div class="hz-card mb-4">
        {% if metadata %}
        <div class="position-absolute top-0 end-0 m-3 p-2 bg-dark bg-opacity-75 rounded">
            <p class="mb-1">Created: <span class="hz-metadata">{{ metadata.created_at.strftime('%Y-%m-%d %H:%M:%S') }}</span></p>
            <p class="mb-0">Updated: <span class="hz-metadata">{{ metadata.updated_at.strftime('%Y-%m-%d %H:%M:%S') }}</span></p>
        </div>
        {% endif %}

        <h1 class="mb-4">{{ wordform_metadata.wordform }}</h1>
        
        <div class="wordform-details mb-4">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <p><strong>Translation:</strong> {{ wordform_metadata.translations|join('; ') if wordform_metadata.translations else 'No translation available' }}</p>
                </div>
                <div class="col-12 col-md-6">
                    <p><strong>Part of Speech:</strong> {{ wordform_metadata.part_of_speech }}</p>
                </div>
                <div class="col-12 col-md-6">
                    <p><strong>Form Type:</strong> {{ wordform_metadata.inflection_type }}</p>
                </div>
                <div class="col-12 col-md-6">
                    <p><strong>Dictionary Form (Lemma):</strong> 
                        {% if wordform_metadata.lemma %}
                        <a href="{{ url_for('lemma_views.get_lemma_metadata_vw', target_language_code=target_language_code, lemma=wordform_metadata.lemma) }}">
                            {{ wordform_metadata.lemma }}
                        </a>
                        {% else %}
                        <em>No lemma linked</em>
                        {% endif %}
                    </p>
                </div>
                {% if wordform_metadata.possible_misspellings %}
                <div class="col-12">
                    <p><strong>Possible Misspellings:</strong> {{ wordform_metadata.possible_misspellings|join(', ') }}</p>
                </div>
                {% endif %}
            </div>
        </div>

        <form action="{{ url_for('wordform_views.delete_wordform_vw', target_language_code=target_language_code, wordform=wordform_metadata.wordform) }}" method="POST" class="d-inline-block" onsubmit="return confirm('Are you sure you want to delete this wordform? This action cannot be undone.');">
            <button type="submit" class="hz-btn-secondary">Delete wordform</button>
        </form>
    </div>

    <div class="hz-card">
        <h2 class="mb-3">Full Dictionary Entry</h2>
        <div class="lemma-details">
            {{ dict_html | safe }}
        </div>
    </div>
</div>
{% endblock %} 